# SUPABASE_SERVICE_ROLE_KEY=jouw-service-role-key

# Alleen nodig wanneer Stripe opnieuw wordt geactiveerd.
# STRIPE_SECRET_KEY=sk_...
# STRIPE_PRICE_ID=price_...
# STRIPE_WEBHOOK_SECRET=whsec_...
